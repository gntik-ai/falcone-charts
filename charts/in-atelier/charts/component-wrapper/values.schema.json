{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "enabled",
    "wrapper",
    "image",
    "replicas",
    "service",
    "resources",
    "persistence"
  ],
  "properties": {
    "enabled": {
      "type": "boolean"
    },
    "wrapper": {
      "type": "object",
      "required": [
        "componentId",
        "workload"
      ],
      "properties": {
        "componentId": {
          "type": "string",
          "minLength": 1
        },
        "workload": {
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "Deployment",
                "StatefulSet"
              ]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "image": {
      "$ref": "#/definitions/image"
    },
    "command": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "args": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "replicas": {
      "type": "integer",
      "minimum": 0
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "service": {
      "$ref": "#/definitions/service"
    },
    "ports": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "resources": {
      "$ref": "#/definitions/resources"
    },
    "env": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "envFromSecrets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "envFromConfigMaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "persistence": {
      "$ref": "#/definitions/persistence"
    },
    "podAnnotations": {
      "type": "object"
    },
    "podLabels": {
      "type": "object"
    },
    "podSecurityContext": {
      "type": "object"
    },
    "securityContext": {
      "type": "object"
    },
    "nodeSelector": {
      "type": "object"
    },
    "tolerations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object"
    },
    "extraVolumes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "extraVolumeMounts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "inline": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "definitions": {
    "image": {
      "type": "object",
      "required": [
        "repository"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:"
        },
        "pullPolicy": {
          "type": "string"
        }
      },
      "anyOf": [
        {
          "required": [
            "tag"
          ]
        },
        {
          "required": [
            "digest"
          ]
        }
      ],
      "additionalProperties": true
    },
    "service": {
      "type": "object",
      "required": [
        "enabled",
        "type",
        "port",
        "targetPort",
        "portName"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "type": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1
        },
        "targetPort": {
          "type": [
            "integer",
            "string"
          ]
        },
        "portName": {
          "type": "string",
          "minLength": 1
        },
        "annotations": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object"
        },
        "limits": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "persistence": {
      "type": "object",
      "required": [
        "enabled",
        "existingClaim",
        "size",
        "storageClass",
        "accessModes",
        "mountPath"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "existingClaim": {
          "type": "string"
        },
        "size": {
          "type": "string"
        },
        "storageClass": {
          "type": "string"
        },
        "accessModes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mountPath": {
          "type": "string",
          "minLength": 1
        },
        "annotations": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  }
}
