        "airgap": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "privateRegistry": {
          "type": "object",
          "required": [
            "enabled",
            "registry",
            "pullSecretNames",
            "caBundleConfigMap"
