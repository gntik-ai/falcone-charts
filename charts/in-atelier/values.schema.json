                "serviceName": {
                  "type": "string"
                },
                "servicePort": {
                  "type": [
                    "string",
                    "integer"
                  ]
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            },
            "identity": {
              "type": "object",
              "required": [
                "component",
                "serviceName",
                "servicePort",
                "path"
              ],
              "properties": {
                "component": {
                  "type": "string",
                  "minLength": 1
                },
                "serviceName": {
                  "type": "string"
                },
                "servicePort": {
                  "type": [
                    "string",
                    "integer"
                  ]
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            },
            "realtime": {
              "type": "object",
              "required": [
                "component",
                "serviceName",
                "servicePort",
                "path"
              ],
              "properties": {
                "component": {
                  "type": "string",
                  "minLength": 1
                },
                "serviceName": {
                  "type": "string"
                },
                "servicePort": {
                  "type": [
                    "string",
                    "integer"
                  ]
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            },
            "console": {
              "type": "object",
              "required": [
                "component",
                "serviceName",
                "servicePort",
                "path"
              ],
              "properties": {
                "component": {
                  "type": "string",
                  "minLength": 1
                },
                "serviceName": {
                  "type": "string"
                },
                "servicePort": {
                  "type": [
                    "string",
                    "integer"
                  ]
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "ingress": {
          "type": "object"
        },
        "route": {
          "type": "object",
          "properties": {
            "annotations": {
              "type": "object"
            },
            "tls": {
              "type": "object",
              "properties": {
                "termination": {
                  "type": "string"
                },
                "insecureEdgeTerminationPolicy": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "tls": {
          "type": "object",
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "clusterManaged",
                "external"
              ]
            }
          },
          "additionalProperties": true
        },
        "loadBalancer": {
          "type": "object",
          "properties": {
            "annotations": {
              "type": "object"
            },
            "className": {
              "type": "string"
            },
            "ports": {
              "type": "object",
              "required": [
                "api",
                "console",
                "identity",
                "realtime"
              ],
              "properties": {
                "api": {
                  "type": "number"
                },
                "console": {
                  "type": "number"
                },
                "identity": {
                  "type": "number"
                },
                "realtime": {
                  "type": "number"
                }
              },
              "additionalProperties": true
            },
            "sourceRanges": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "externalTrafficPolicy": {
              "type": "string",
              "enum": [
                "Cluster",
                "Local"
              ]
            },
            "ipFamilyPolicy": {
              "type": "string"
            },
            "ipFamilies": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "allocateLoadBalancerNodePorts": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "environmentProfile": {
      "type": "object"
    },
    "deployment": {
      "type": "object",
      "required": [
        "topology",
        "valuesLayers",
        "profile",
        "recommendedProfiles",
        "upgrade"
      ],
      "properties": {
        "topology": {
          "type": "object"
        },
        "valuesLayers": {
          "type": "object",
          "required": [
            "common",
            "environment",
            "customer",
            "platform",
            "airgap",
            "localOverride"
          ],
          "properties": {
            "common": {
              "type": "string"
            },
            "environment": {
              "type": "string"
            },
            "customer": {
              "type": "string"
            },
            "platform": {
              "type": "string"
            },
            "airgap": {
              "type": "string"
            },
            "localOverride": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "profile": {
          "type": "string",
          "enum": [
            "all-in-one",
            "standard",
            "ha"
          ]
        },
        "recommendedProfiles": {
          "type": "object",
          "required": [
            "default",
            "pathPattern",
            "supported"
          ],
          "properties": {
            "default": {
              "type": "string",
              "enum": [
                "standard"
              ]
            },
            "pathPattern": {
              "type": "string"
            },
            "supported": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "all-in-one",
                  "standard",
                  "ha"
                ]
              }
            }
          },
          "additionalProperties": true
        },
        "upgrade": {
          "type": "object",
          "required": [
            "allowInPlace",
            "currentVersion",
            "supportedPreviousVersions",
            "allowDowngrade",
            "strategy"
          ],
          "properties": {
            "allowInPlace": {
              "type": "boolean"
            },
            "currentVersion": {
              "type": "string"
            },
            "supportedPreviousVersions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "allowDowngrade": {
              "type": "boolean"
            },
            "strategy": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "platform": {
      "type": "object"
    },
    "config": {
      "type": "object"
    },
    "apisix": {
      "$ref": "#/definitions/component"
    },
    "keycloak": {
      "$ref": "#/definitions/component"
    },
    "postgresql": {
      "$ref": "#/definitions/component"
    },
    "mongodb": {
      "$ref": "#/definitions/component"
    },
    "kafka": {
      "$ref": "#/definitions/component"
    },
    "openwhisk": {
      "$ref": "#/definitions/component"
    },
    "storage": {
      "$ref": "#/definitions/component"
    },
    "observability": {
      "$ref": "#/definitions/component"
    },
    "controlPlane": {
      "$ref": "#/definitions/component"
    },
    "webConsole": {
      "$ref": "#/definitions/component",
      "properties": {
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "issuerUrl",
            "realm",
            "clientId",
            "grantType",
            "tokenStorage",
            "loginPath",
            "signupPath",
            "pendingActivationPath",
            "suspendedPath",
            "credentialsExpiredPath",
            "passwordRecoveryPath",
            "autoSignupPolicy",
            "statusMessages"
          ],
          "properties": {
            "issuerUrl": {
              "type": "string"
            },
            "realm": {
              "type": "string"
            },
            "clientId": {
              "type": "string"
            },
            "grantType": {
              "type": "string",
              "enum": [
                "password"
              ]
            },
            "tokenStorage": {
              "type": "string",
              "enum": [
                "memory_with_refresh_rotation"
              ]
            },
            "loginPath": {
              "type": "string"
            },
            "signupPath": {
              "type": "string"
            },
            "pendingActivationPath": {
              "type": "string"
            },
            "suspendedPath": {
              "type": "string"
            },
            "credentialsExpiredPath": {
              "type": "string"
            },
            "passwordRecoveryPath": {
              "type": "string"
            },
            "autoSignupPolicy": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "globalMode",
                "environmentModes",
                "planModes"
              ],
              "properties": {
                "globalMode": {
                  "type": "string",
                  "enum": [
                    "disabled",
                    "approval_required",
                    "auto_activate"
                  ]
                },
                "environmentModes": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string",
                    "enum": [
                      "disabled",
                      "approval_required",
                      "auto_activate"
                    ]
                  }
                },
                "planModes": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string",
                    "enum": [
                      "disabled",
                      "approval_required",
                      "auto_activate"
                    ]
                  }
                }
              }
            },
            "statusMessages": {
              "type": "object",
              "required": [
                "pending_activation",
                "account_suspended",
                "credentials_expired"
              ],
              "additionalProperties": {
                "type": "string"
              },
              "properties": {
                "pending_activation": {
                  "type": "string"
                },
                "account_suspended": {
                  "type": "string"
                },
                "credentials_expired": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "bootstrap": {
      "type": "object",
      "required": [
        "enabled",
        "serviceAccount",
        "job",
        "lock",
        "markers",
        "secretResolution",
        "oneShot",
        "reconcile"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "serviceAccount": {
          "type": "object",
          "required": [
            "create",
            "name"
          ],
          "properties": {
            "create": {
              "type": "boolean"
            },
            "name": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "job": {
          "type": "object",
          "required": [
            "image",
            "backoffLimit",
            "activeDeadlineSeconds",
            "ttlSecondsAfterFinished",
            "extraEnv"
          ],
          "properties": {
            "image": {
              "type": "object",
              "required": [
                "repository",
                "tag",
                "pullPolicy"
              ],
              "properties": {
                "repository": {
                  "type": "string",
                  "minLength": 1
                },
                "tag": {
                  "type": [
                    "string",
                    "number"
                  ]
                },
                "pullPolicy": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            },
            "backoffLimit": {
              "type": "integer",
              "minimum": 0
            },
            "activeDeadlineSeconds": {
              "type": "integer",
              "minimum": 1
            },
            "ttlSecondsAfterFinished": {
              "type": "integer",
              "minimum": 0
            },
            "annotations": {
              "type": "object"
            },
            "podAnnotations": {
              "type": "object"
            },
            "podLabels": {
              "type": "object"
            },
            "podSecurityContext": {
              "type": "object"
            },
            "securityContext": {
              "type": "object"
            },
            "resources": {
              "type": "object"
            },
            "nodeSelector": {
              "type": "object"
            },
            "tolerations": {
              "type": "array"
            },
            "affinity": {
              "type": "object"
            },
            "extraEnv": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "value": {
                    "type": "string"
                  },
                  "valueFrom": {
                    "type": "object"
                  }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "lock": {
          "type": "object",
          "required": [
            "name",
            "breakGlassExistingLock"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "breakGlassExistingLock": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "markers": {
          "type": "object",
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        },
        "secretResolution": {
          "type": "object",
          "required": [
            "supportedStrategies",
            "sources"
          ],
          "properties": {
            "supportedStrategies": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "kubernetesSecret",
                  "env",
                  "externalRef"
                ]
              },
              "minItems": 3
            },
            "sources": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "object",
                "required": [
                  "strategy",
                  "envVarName"
                ],
                "properties": {
                  "strategy": {
                    "type": "string",
                    "enum": [
                      "kubernetesSecret",
                      "env",
                      "externalRef"
                    ]
                  },
                  "envVarName": {
                    "type": "string",
                    "minLength": 1
                  },
                  "existingSecret": {
                    "type": "object",
                    "required": [
                      "name",
                      "key"
                    ],
                    "properties": {
                      "name": {
                        "type": "string",
                        "minLength": 1
                      },
                      "key": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "additionalProperties": true
                  },
                  "externalRef": {
                    "type": "object",
                    "required": [
                      "provider",
                      "reference"
                    ],
                    "properties": {
                      "provider": {
                        "type": "string",
                        "minLength": 1
                      },
                      "reference": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "additionalProperties": true
                  }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "oneShot": {
          "type": "object",
          "required": [
            "keycloak",
            "governanceCatalog",
            "internalNamespaces"
          ],
          "properties": {
            "keycloak": {
              "type": "object",
              "required": [
                "realm",
                "realmRoles",
                "clientScopes",
                "clients",
                "tenantRealmTemplate",
                "superadmin"
              ],
              "properties": {
                "realm": {
                  "type": "object",
                  "required": [
                    "realm",
                    "displayName",
                    "enabled"
                  ],
                  "properties": {
                    "realm": {
                      "type": "string",
                      "minLength": 1
                    },
                    "displayName": {
                      "type": "string",
                      "minLength": 1
                    },
                    "enabled": {
                      "type": "boolean"
                    },
                    "login": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "loginWithEmailAllowed",
                        "registrationAllowed",
                        "rememberMe",
                        "verifyEmail",
                        "resetPasswordAllowed"
                      ],
                      "properties": {
                        "loginWithEmailAllowed": {
                          "type": "boolean"
                        },
                        "registrationAllowed": {
                          "type": "boolean"
                        },
                        "rememberMe": {
                          "type": "boolean"
                        },
                        "verifyEmail": {
                          "type": "boolean"
                        },
                        "resetPasswordAllowed": {
                          "type": "boolean"
                        }
                      }
                    }
                  },
                  "additionalProperties": true
                },
                "superadmin": {
                  "type": "object",
                  "required": [
                    "username",
                    "email",
                    "firstName",
                    "lastName",
                    "realmRoles"
                  ],
                  "properties": {
                    "username": {
                      "type": "string",
                      "minLength": 1
                    },
                    "email": {
                      "type": "string",
                      "minLength": 1
                    },
                    "firstName": {
                      "type": "string",
                      "minLength": 1
                    },
                    "lastName": {
                      "type": "string",
                      "minLength": 1
                    },
                    "realmRoles": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      },
                      "minItems": 1
                    }
                  },
                  "additionalProperties": true
                },
                "realmRoles": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "clientScopes": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": [
                      "name",
                      "protocol"
                    ],
                    "properties": {
                      "name": {
                        "type": "string",
                        "minLength": 1
                      },
                      "protocol": {
                        "type": "string",
                        "minLength": 1
                      },
                      "attributes": {
                        "type": "object"
                      },
                      "protocolMappers": {
                        "type": "array"
                      }
                    },
                    "additionalProperties": true
                  }
                },
                "clients": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": [
                      "clientId",
                      "protocol",
                      "enabled"
                    ],
                    "properties": {
                      "clientId": {
                        "type": "string",
                        "minLength": 1
                      },
                      "name": {
                        "type": "string"
                      },
                      "protocol": {
                        "type": "string",
                        "minLength": 1
                      },
                      "enabled": {
                        "type": "boolean"
                      },
                      "bearerOnly": {
                        "type": "boolean"
                      },
                      "publicClient": {
                        "type": "boolean"
                      },
                      "serviceAccountsEnabled": {
                        "type": "boolean"
                      },
                      "standardFlowEnabled": {
                        "type": "boolean"
                      },
                      "directAccessGrantsEnabled": {
                        "type": "boolean"
                      },
                      "redirectUris": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "webOrigins": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "defaultClientScopes": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "minLength": 1
                        }
                      }
                    },
                    "additionalProperties": true
