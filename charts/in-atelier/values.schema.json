        "hostnames": {
          "type": "object",
          "required": [
            "api",
            "console",
            "identity",
            "realtime"
          ],
          "properties": {
            "api": {
              "type": "string",
              "minLength": 1
            },
            "console": {
              "type": "string",
              "minLength": 1
            },
            "identity": {
              "type": "string",
              "minLength": 1
            },
            "realtime": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        },
        "certificates": {
          "type": "object",
          "required": [
