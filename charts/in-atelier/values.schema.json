            "identity",
            "realtime",
            "console"
          ],
          "properties": {
            "controlPlane": {
              "type": "string"
            },
            "identity": {
              "type": "string"
            },
            "realtime": {
              "type": "string"
            },
            "console": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "optionalWorkspaceSubdomains": {
          "type": "object"
