          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "registry": {
              "type": "string"
            },
            "pullSecretNames": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "caBundleConfigMap": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "defaultStorageClass": {
          "type": "string"
        },
        "podSecurity": {
          "type": "object"
        }
      },
      "additionalProperties": true
