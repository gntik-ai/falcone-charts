{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "global",
    "publicSurface",
    "environmentProfile",
    "deployment",
    "platform",
    "gatewayPolicy",
    "config",
    "bootstrap",
    "apisix",
    "keycloak",
    "postgresql",
    "mongodb",
    "kafka",
    "openwhisk",
    "storage",
    "observability",
    "controlPlane",
    "webConsole"
  ],
  "properties": {
    "global": {
      "type": "object",
      "required": [
        "nameOverride",
        "namespace",
        "environment",
        "createNamespace",
        "airgap",
        "privateRegistry"
      ],
      "properties": {
        "nameOverride": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "enum": [
            "dev",
            "sandbox",
            "staging",
            "prod"
          ]
        },
        "createNamespace": {
          "type": "boolean"
        },
        "imageRegistry": {
          "type": "string"
        },
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "type": [
              "string",
              "object"
            ]
          }
